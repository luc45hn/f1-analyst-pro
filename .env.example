# ── Anthropic ─────────────────────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Opcional — defaults mostrados
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=8192

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtener en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# Solo necesaria si usás operaciones de admin server-side
# SUPABASE_SECRET_KEY=your_service_role_key_here

# Obtener en: Supabase Dashboard → Settings → Database → Connection string (URI)
# Usar el connection pooler (puerto 6543) para compatibilidad con psycopg2
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# ── Temporada ─────────────────────────────────────────────────────────────────
# YEAR=2026
