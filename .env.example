# Clave de API de Anthropic (requerida)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Temporada a analizar (opcional, default: 2026)
# YEAR=2026

# Modelo de Claude a usar (opcional, default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Tokens máximos por respuesta (opcional, default: 8192)
# ANTHROPIC_MAX_TOKENS=8192
